# ============================================
# SEBRAEIERS — Environment Variables
# ============================================
# Copie para .env.local e preencha com seus valores reais
# (NUNCA commite o .env.local)

# ===== Supabase =====
# Encontre esses valores no painel do Supabase:
# Settings → API → Project URL e Project API keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — APENAS server-side, NUNCA no client
# Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ===== Admin bootstrap =====
# Contas com email @conteudoedu.com.br são promovidas a admin automaticamente
# no signup (ver migration 0009_agency_admin_domain.sql).

# ===== App =====
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SEBRAEIERS

# ===== Google Sheets sync =====
# ID da planilha (do URL: docs.google.com/spreadsheets/d/{ID}/edit)
SHEET_ID=
# GID da aba (default 0 = primeira aba)
SHEET_GID=0
# Mapeamento de colunas opcional (formato: key=value,key=value)
# Defaults: link_post=link_post, data_publicacao=data_publicacao, titulo=titulo,
# descricao=descricao, rede=rede, thumbnail=thumbnail
# SHEET_COL_MAP=link_post=Link,data_publicacao=Data,titulo=Título da Publicação,rede=Rede/Formato
# Secreto do cron (Cloudflare Worker / HTTP scheduler). Gere com: openssl rand -hex 32
CRON_SECRET=